[Icon Theme]
Name=TahoeIcons
Comment=Tahoe local icon theme backed by ./assets imagery
Directories=apps/256x256,status/64x64,places/256x256
Inherits=hicolor

[apps/256x256]
Size=256
Context=Applications
Type=Fixed

[status/64x64]
Size=64
Context=Status
Type=Threshold
Threshold=32

[places/256x256]
Size=256
Context=Places
Type=Fixed
