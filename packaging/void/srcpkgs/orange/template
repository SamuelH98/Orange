# Template file for 'orange'
pkgname=orange
version=0.1.0
revision=4
build_style=meson
hostmakedepends="pkg-config wayland-devel wayland-protocols"
makedepends="cairo-devel libdrm-devel pixman-devel wayland-devel
 wlroots0.20-devel libxkbcommon-devel librsvg-devel gdk-pixbuf-devel
 glib-devel elogind-devel wayland-protocols"
depends="dbus elogind polkit gdm xorg-server-xwayland
 gnome-session gnome-settings-daemon
 gnome-apps ghostty nautilus gvfs
 firefox gnome-software
 hicolor-icon-theme adwaita-icon-theme adwaita-fonts
 gnome-themes-extra gnome-themes-extra-gtk gnome-backgrounds
 dejavu-fonts-ttf mesa-dri ModemManager wl-clipboard"
short_desc="macOS-like wlroots compositor"
maintainer="local <root@localhost>"
license="custom:local"
homepage="https://example.invalid/orange"
skip_extraction=yes

do_extract() {
	mkdir -p "${wrksrc}"
	cp -a "${FILESDIR}/src/." "${wrksrc}"
}

do_install() {
	vbin build/orange
	vinstall "${FILESDIR}/orange-session" 0755 usr/bin
	vinstall "${FILESDIR}/orange.desktop" 0644 usr/share/wayland-sessions
	vinstall orange.conf 0644 usr/share/orange
	vlicense "${FILESDIR}/LICENSE"
}

post_install() {
	# ── dconf profile for GDM ──
	vmkdir etc/dconf/profile 0755
	printf 'user-db:user\nsystem-db:local\n' > $DESTDIR/etc/dconf/profile/gdm

	# ── dconf database ──
	vmkdir etc/dconf/db 0755
	touch $DESTDIR/etc/dconf/db/local

	# ── GDM custom.conf ──
	vmkdir etc/gdm 0755
	cat > $DESTDIR/etc/gdm/custom.conf <<'GDMCONF'
[daemon]
WaylandEnable=true
InitialSetupEnable=false

[security]

[xdmcp]

[chooser]

[debug]
GDMCONF

	# ── PAM config for GDM (elogind) ──
	vmkdir etc/pam.d 0755
	cat > $DESTDIR/etc/pam.d/gdm <<'GDMPAM'
#%PAM-1.0

auth       required     pam_securetty.so
auth       requisite    pam_nologin.so
auth       include      system-login
account    include      system-login
password   include      system-login
session    include      system-login
-session   optional     pam_elogind.so
GDMPAM

	# ── D-Bus launch helper setuid (required by GDM/AccountsService) ──
	vmkdir usr/libexec 0755
	if [ -f $DESTDIR/usr/libexec/dbus-daemon-launch-helper ]; then
		chmod u+s $DESTDIR/usr/libexec/dbus-daemon-launch-helper
	fi

	# ── GDM greeter directory ──
	vmkdir var/lib/gdm/greeter 0755

	# ── GDM runit service ──
	vmkdir etc/sv/gdm 0755
	cat > $DESTDIR/etc/sv/gdm/run <<'GDMRUN'
#!/bin/sh
exec 2>&1

# Create elogind seat file so sd_seat_can_graphical() returns true.
mkdir -p /run/systemd/seats
cat > /run/systemd/seats/seat0 <<'SEAT'
# This is private data. Do not parse.
CAN_GRAPHICAL=yes
CAN_TTY=yes
SEAT

[ ! -d /run/gdm ] && mkdir -m0711 -p /run/gdm && chown root:gdm /run/gdm
[ ! -d /var/lib/gdm/greeter ] && mkdir -m0755 -p /var/lib/gdm/greeter && chown gdm:gdm /var/lib/gdm/greeter
exec gdm
GDMRUN
	chmod +x $DESTDIR/etc/sv/gdm/run

	# ── XDG_RUNTIME_DIR base ──
	vmkdir run/user 0755

	# ── Enable runit services ──
	for svc in dbus elogind polkitd gdm; do
		if [ -d "$DESTDIR/etc/sv/${svc}" ] && [ ! -e "$DESTDIR/var/service/${svc}" ]; then
			vmkdir var/service 0755
			ln -sf "/etc/sv/${svc}" "$DESTDIR/var/service/${svc}"
		fi
	done
}
