# Template file for 'orange'
pkgname=orange
version=0.1.0
revision=3
build_style=meson
hostmakedepends="pkg-config wayland-devel wayland-protocols"
makedepends="cairo-devel libdrm-devel pixman-devel wayland-devel
 wlroots0.20-devel libxkbcommon-devel librsvg-devel gdk-pixbuf-devel
 glib-devel elogind-devel wayland-protocols"
depends="dbus elogind polkit gdm xorg-server-xwayland
 gnome-session gnome-settings-daemon
 gnome-apps ghostty nautilus gvfs
 firefox gnome-software
 hicolor-icon-theme adwaita-icon-theme adwaita-fonts
 gnome-themes-extra gnome-themes-extra-gtk gnome-backgrounds
 dejavu-fonts-ttf mesa-dri ModemManager wl-clipboard"
short_desc="macOS-like wlroots compositor"
maintainer="local <root@localhost>"
license="custom:local"
homepage="https://example.invalid/orange"
skip_extraction=yes

do_extract() {
	mkdir -p "${wrksrc}"
	cp -a "${FILESDIR}/src/." "${wrksrc}"
}

do_install() {
	vbin build/orange
	vinstall "${FILESDIR}/orange-session" 0755 usr/bin
	vinstall "${FILESDIR}/orange.desktop" 0644 usr/share/wayland-sessions
	vinstall orange.conf 0644 usr/share/orange
	vinstall "${FILESDIR}/orange-setup.sh" 0755 usr/bin orange-setup
	vlicense "${FILESDIR}/LICENSE"
}

post_install() {
	# dconf profile for GDM
	vmkdir etc/dconf/profile 0755
	printf 'user-db:user\nsystem-db:local\n' > $DESTDIR/etc/dconf/profile/gdm

	# XDG_RUNTIME_DIR base
	vmkdir run/user 0755

	# D-Bus launch helper setuid (required by GDM/AccountsService)
	vmkdir usr/libexec 0755
	if [ -f $DESTDIR/usr/libexec/dbus-daemon-launch-helper ]; then
		chmod u+s $DESTDIR/usr/libexec/dbus-daemon-launch-helper
	fi
}
